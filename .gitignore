# ============================================================
# .gitignore - AI 智能客服系统
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.so
*.egg-info/
dist/
build/
.eggs/
*.whl

# --- 虚拟环境 ---
.venv/
venv/
env/

# --- 环境变量（包含敏感信息）---
.env

# --- 上传文件 ---
uploads/*
!uploads/.gitkeep

# --- ChromaDB 数据 ---
chroma_db/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- 日志 ---
*.log
logs/

# --- Docker ---
.dockerignore
*.lnk
